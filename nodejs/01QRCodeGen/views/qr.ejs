
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>QR</title>

    <!-- Bootstrap CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background-color: #eef3f9;
        }

        .card {
            border-radius: 15px;
            background: linear-gradient(135deg, #0d6efd, #4dabf7); /* blue gradient */
            color: white;
        }

        .qr-img {
            width: 250px;
            height: 250px;
            object-fit: contain;
            display: block;
            margin: 0 auto; /* center image */
            background: white;
            padding: 10px;
            border-radius: 10px;
        }
    </style>
</head>
<body>

    <div class="container d-flex justify-content-center align-items-center vh-100">
        <div class="card shadow text-center p-4" style="width: 360px;">
            
            <h4 class="mb-3">Generated QR</h4>

            <img src="<%= QRUrl %>" alt="qrimage" class="qr-img mb-3">
             <a href="/download-qr?url=<%= qrText %>" class="btn btn-light mt-2 w-100"> Download QR </a>
            <p>Scan Me</p>


            

        </div>
    </div>

</body>
</html>
